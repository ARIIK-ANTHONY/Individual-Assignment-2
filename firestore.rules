rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // User can access only their own profile document.
    match /users/{userId} {
      allow create, read, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Listings are publicly readable for the directory.
    match /listings/{listingId} {
      allow read: if true;

      // Creator must match the authenticated user.
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid;

      // Owner can fully edit/delete their listing.
      allow update, delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      // Any signed-in user may update only aggregate review fields.
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).changedKeys()
                       .hasOnly(['rating', 'reviewCount']);
    }

    // Reviews are readable by everyone; writes are restricted to reviewer.
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Deny all other documents by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}