{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Flutter Android Emulator",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"emulator-5554"
			],
			"isBackground": true
		},
		{
			"label": "Run Flutter Android (cmd)",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"flutter run -d emulator-5554"
			],
			"isBackground": true
		}
	]
}